# Ollama Configuration
# Copy this file to .env and adjust values as needed

# Host binding for Ollama service
# Set to 0.0.0.0 to allow external connections
# Set to 127.0.0.1 to only allow local connections
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_ORIGIN=http://localhost:11434
OLLAMA_LOG_LEVEL=info

# The name of the ollama container
OLLAMA_CONTAINER_NAME=ollama-server

# The name of the network to create/use
OLLAMA_NETWORK_NAME=ollama_network

# The local path to store Ollama data (bind mount)
OLLAMA_DATA_PATH=./ollama_data