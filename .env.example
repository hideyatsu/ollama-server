# Ollama Configuration
# Copy this file to .env and adjust values as needed

# Host binding for Ollama service
# Set to 0.0.0.0 to allow external connections
# Set to 127.0.0.1 to only allow local connections
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_ORIGIN=http://localhost:11434
OLLAMA_LOG_LEVEL=info

# LiteLLM Configuration
LITELLM_PORT=4000
LITELLM_CONTAINER_NAME=litellm-proxy
LITELLM_MASTER_KEY=your-secret-key-here
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=your-password-here

# LiteLLM DB Configuration
LITELLM_DB_CONTAINER_NAME=litellm-db
LITELLM_DB_PORT=5432
LITELLM_DB_NAME=litellm
LITELLM_DB_USERNAME=litellm
LITELLM_DB_PASSWORD=litellm

# Resource limits
OLLAMA_CPU_LIMIT=4
OLLAMA_MEMORY_LIMIT=16G

# The name of the ollama container
OLLAMA_CONTAINER_NAME=ollama-server

# The name of the network to create/use
OLLAMA_NETWORK_NAME=ollama_network

# The local path to store Ollama data (bind mount)
OLLAMA_DATA_PATH=./ollama_data